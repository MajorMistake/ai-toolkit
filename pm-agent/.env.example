# VertexAI / Gemini configuration
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=cyderes-test
GOOGLE_CLOUD_LOCATION=us-central1

# Jira configuration
JIRA_BASE_URL=https://cyderes.atlassian.net
JIRA_EMAIL=your-email@cyderes.com
JIRA_API_TOKEN=your-token-here
JIRA_BOARD_ID=your-board-id

# Agent configuration
USE_MOCK_JIRA=true
JIRA_WRITE_MODE=local_only
VAULT_PATH=~/obsidian-vault/pm-agent
LOG_PATH=~/.pm-agent/logs

# Cost tracking
COST_LOG_PATH=~/.pm-agent/cost_log.jsonl
AGENT_LABEL=pm-agent
